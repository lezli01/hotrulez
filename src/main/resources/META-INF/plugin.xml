<idea-plugin>
    <id>dev.lezli.hotrulez</id>
    <name>hotrulez</name>
    <vendor url="https://lezli01.is-a.dev">lezli01</vendor>

    <description><![CDATA[
        <p>
            Language support for <b>Firebase Cloud Firestore Security Rules</b>
            (<code>.rules</code> files) in JetBrains IDEs.
        </p>
        <p>Features:</p>
        <ul>
            <li>Syntax highlighting with a configurable color scheme</li>
            <li>Structural validation and inspections (file-structure and
                suspicious-usage warnings)</li>
            <li>Code formatting, brace matching, quote handling, and line/block
                commenting</li>
            <li><b>Symbol intelligence</b> &mdash; go to definition, find usages,
                and rename for functions, parameters, <code>let</code> bindings,
                and path variables, with Firestore-aware scoping and
                path-variable shadowing</li>
            <li><b>Scope-aware code completion</b> for keywords,
                <code>allow</code> operations, in-scope symbols, built-ins
                (<code>request</code>, <code>resource</code>), helper functions,
                and shallow <code>request.</code>/<code>resource.</code>
                members</li>
        </ul>
        <p>
            hotrulez is purely structural: it never connects to Firebase, runs
            the emulator, or evaluates whether a rule authorizes a request.
        </p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Firestore Rules"
            implementationClass="dev.lezli.hotrulez.FirebaseRulesFileType"
            fieldName="INSTANCE"
            language="FirebaseRules"
            extensions="rules"/>

        <lang.syntaxHighlighterFactory
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.highlighting.FirebaseRulesSyntaxHighlighterFactory"/>

        <annotator
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.highlighting.FirebaseRulesAnnotator"/>

        <colorSettingsPage
            implementation="dev.lezli.hotrulez.highlighting.FirebaseRulesColorSettingsPage"/>

        <lang.parserDefinition
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.parser.FirebaseRulesParserDefinition"/>

        <lang.formatter
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.formatting.FirebaseRulesFormattingModelBuilder"/>

        <lang.braceMatcher
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.editor.FirebaseRulesBraceMatcher"/>

        <lang.quoteHandler
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.editor.FirebaseRulesQuoteHandler"/>

        <lang.commenter
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.editor.FirebaseRulesCommenter"/>

        <annotator
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.diagnostics.FirebaseRulesAnnotator"/>

        <localInspection
            language="FirebaseRules"
            shortName="FirebaseRulesStructure"
            displayName="Firestore Rules file structure"
            groupName="Firestore Rules"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="dev.lezli.hotrulez.diagnostics.FirebaseRulesStructureInspection"/>

        <localInspection
            language="FirebaseRules"
            shortName="FirebaseRulesUsage"
            displayName="Firestore Rules suspicious usage"
            groupName="Firestore Rules"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="dev.lezli.hotrulez.diagnostics.FirebaseRulesUsageInspection"/>

        <!-- Symbol intelligence (v2): resolve/go-to-definition, find usages, rename, completion.
             References are attached directly on the PSI (see
             FirebaseRulesReferenceExpressionMixin.getReference()), so no
             psi.referenceContributor is registered. -->
        <lang.elementManipulator
            forClass="dev.lezli.hotrulez.psi.impl.FirebaseRulesReferenceExpressionImpl"
            implementationClass="dev.lezli.hotrulez.references.FirebaseRulesReferenceManipulator"/>

        <lang.findUsagesProvider
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.findusages.FirebaseRulesFindUsagesProvider"/>

        <lang.namesValidator
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.refactoring.FirebaseRulesNamesValidator"/>

        <completion.contributor
            language="FirebaseRules"
            implementationClass="dev.lezli.hotrulez.completion.FirebaseRulesCompletionContributor"/>

        <renamePsiElementProcessor
            implementation="dev.lezli.hotrulez.refactoring.FirebaseRulesPathVariableRenameProcessor"/>
    </extensions>
</idea-plugin>
