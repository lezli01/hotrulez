<idea-plugin>
    <id>dev.lezli.hotrulez</id>
    <name>hotrulez</name>
    <vendor url="https://lezli01.is-a.dev">lezli01</vendor>

    <description><![CDATA[
        <p>
            Language support for <b>Firebase Cloud Firestore Security Rules</b>
            (<code>.rules</code> files) in JetBrains IDEs.
        </p>
        <p>Features:</p>
        <ul>
            <li>Syntax highlighting with a configurable color scheme</li>
            <li>Structural validation and inspections (file-structure and
                suspicious-usage warnings)</li>
            <li>Code formatting, brace matching, quote handling, and line/block
                commenting</li>
            <li><b>Symbol intelligence</b> &mdash; go to definition, find usages,
                and rename for functions, parameters, <code>let</code> bindings,
                and path variables, with Firestore-aware scoping and
                path-variable shadowing</li>
            <li><b>Scope-aware code completion</b> for keywords,
                <code>allow</code> operations, in-scope symbols, built-ins
                (<code>request</code>, <code>resource</code>), helper functions,
                and shallow <code>request.</code>/<code>resource.</code>
                members</li>
        </ul>
        <p>
            hotrulez is purely structural: it never connects to Firebase, runs
            the emulator, or evaluates whether a rule authorizes a request.
        </p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Firestore Rules"
            implementationClass="dev.lezli.hotrulez.FirestoreRulesFileType"
            fieldName="INSTANCE"
            language="FirestoreRules"
            extensions="rules"/>

        <lang.syntaxHighlighterFactory
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.highlighting.FirestoreRulesSyntaxHighlighterFactory"/>

        <annotator
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.highlighting.FirestoreRulesAnnotator"/>

        <colorSettingsPage
            implementation="dev.lezli.hotrulez.highlighting.FirestoreRulesColorSettingsPage"/>

        <lang.parserDefinition
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.parser.FirestoreRulesParserDefinition"/>

        <lang.formatter
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.formatting.FirestoreRulesFormattingModelBuilder"/>

        <lang.braceMatcher
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.editor.FirestoreRulesBraceMatcher"/>

        <lang.quoteHandler
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.editor.FirestoreRulesQuoteHandler"/>

        <lang.commenter
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.editor.FirestoreRulesCommenter"/>

        <annotator
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.diagnostics.FirestoreRulesAnnotator"/>

        <localInspection
            language="FirestoreRules"
            shortName="FirestoreRulesStructure"
            displayName="Firestore Rules file structure"
            groupName="Firestore Rules"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="dev.lezli.hotrulez.diagnostics.FirestoreRulesStructureInspection"/>

        <localInspection
            language="FirestoreRules"
            shortName="FirestoreRulesUsage"
            displayName="Firestore Rules suspicious usage"
            groupName="Firestore Rules"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="dev.lezli.hotrulez.diagnostics.FirestoreRulesUsageInspection"/>

        <!-- Symbol intelligence (v2): resolve/go-to-definition, find usages, rename, completion.
             References are attached directly on the PSI (see
             FirestoreRulesReferenceExpressionMixin.getReference()), so no
             psi.referenceContributor is registered. -->
        <lang.elementManipulator
            forClass="dev.lezli.hotrulez.psi.impl.FirestoreRulesReferenceExpressionImpl"
            implementationClass="dev.lezli.hotrulez.references.FirestoreRulesReferenceManipulator"/>

        <lang.findUsagesProvider
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.findusages.FirestoreRulesFindUsagesProvider"/>

        <lang.namesValidator
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.refactoring.FirestoreRulesNamesValidator"/>

        <completion.contributor
            language="FirestoreRules"
            implementationClass="dev.lezli.hotrulez.completion.FirestoreRulesCompletionContributor"/>

        <renamePsiElementProcessor
            implementation="dev.lezli.hotrulez.refactoring.FirestoreRulesPathVariableRenameProcessor"/>
    </extensions>
</idea-plugin>
